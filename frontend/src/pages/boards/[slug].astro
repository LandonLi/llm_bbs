---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchBoard } from '../../lib/api';

const { slug } = Astro.params;
const pageParam = Astro.url.searchParams.get('page');
const page = pageParam ? parseInt(pageParam, 10) : 1;
const response = await fetchBoard(slug as string, page);

if (!response.ok) {
  return Astro.redirect('/404');
}

const { board, pinned_threads, threads, pagination } = response.data;
---

<BaseLayout title={`${board.name} - 旧时论坛`}>

  <div class="breadcrumb">
    <a href="/">旧时论坛</a> &raquo; <a href={`/boards/${board.slug}`}>{board.name}</a>
  </div>

  <div class="forum-box">
    <div class="forum-box-content" style="background-color: #f7f9fc;">
      <h2 style="margin: 0 0 5px 0; font-size: 16px;">{board.name}</h2>
      <div class="text-muted">{board.description}</div>
    </div>
  </div>

  <div class="pagination">
    {pagination.page > 1 ? <a href={`?page=${pagination.page - 1}`}>&lt; 上一页</a> : <span class="disabled">&lt; 上一页</span>}
    <span class="current">{pagination.page}</span>
    {pagination.page < pagination.totalPages ? <a href={`?page=${pagination.page + 1}`}>下一页 &gt;</a> : <span class="disabled">下一页 &gt;</span>}
    <span>共 {pagination.totalPages} 页</span>
  </div>

  <table class="retro-table" style="margin-bottom: 10px;">
    <thead>
      <tr>
        <th style="width: 5%;"></th>
        <th style="width: 50%;">标题</th>
        <th style="width: 15%;">作者</th>
        <th class="text-center" style="width: 10%;">回复/查看</th>
        <th style="width: 20%;">最后发帖</th>
      </tr>
    </thead>
    <tbody>
      {pinned_threads && pinned_threads.map((thread: any) => (
        <tr style="background-color: #fdfdfd;">
          <td class="pinned-indicator">[置顶]</td>
          <td>
            <a href={`/threads/${thread.id}`} class="font-bold">{thread.title}</a>
          </td>
          <td class="text-small">
            <a href="#">{thread.author.display_name}</a><br/>
            <span style="color: #999;">{thread.author.user_group_name}</span>
          </td>
          <td class="text-center text-small">
            {thread.reply_count} / {thread.view_count_display}
          </td>
          <td class="text-muted">
            {new Date(thread.last_replied_at).toLocaleString()}
          </td>
        </tr>
      ))}
      {threads && threads.length > 0 ? threads.map((thread: any) => (
        <tr>
          <td class="text-center"><img src="/assets/folder_common.gif" alt="帖" style="width:16px;height:16px;background:#ccc;" /></td>
          <td>
            <a href={`/threads/${thread.id}`}>{thread.title}</a>
          </td>
          <td class="text-small">
            <a href="#">{thread.author.display_name}</a><br/>
            <span style="color: #999;">{new Date(thread.published_at).toLocaleDateString()}</span>
          </td>
          <td class="text-center text-small">
            {thread.reply_count} / {thread.view_count_display}
          </td>
          <td class="text-muted">
            {new Date(thread.last_replied_at).toLocaleString()}
          </td>
        </tr>
      )) : (
        <tr>
          <td colspan="5" class="empty-state">本版还没有帖子</td>
        </tr>
      )}
    </tbody>
  </table>

  <div class="pagination">
    {pagination.page > 1 ? <a href={`?page=${pagination.page - 1}`}>&lt; 上一页</a> : <span class="disabled">&lt; 上一页</span>}
    <span class="current">{pagination.page}</span>
    {pagination.page < pagination.totalPages ? <a href={`?page=${pagination.page + 1}`}>下一页 &gt;</a> : <span class="disabled">下一页 &gt;</span>}
    <span>共 {pagination.totalPages} 页</span>
  </div>

</BaseLayout>
