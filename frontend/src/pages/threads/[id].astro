---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchThread, fetchThreadPosts, fetchThreadIds } from '../../lib/api';

export async function getStaticPaths() {
  const ids = await fetchThreadIds();
  return ids.map((id: string) => ({
    params: { id }
  }));
}

const { id } = Astro.params;
const threadRes = await fetchThread(id as string);
const postsRes = await fetchThreadPosts(id as string, 1);

const { board, thread } = threadRes.data;
const { posts, pagination } = postsRes.data;

// 为了方便渲染，我们将主楼视为第 1 楼 (楼主)，跟帖附加在后面
const mainPost = {
  id: thread.id,
  floor_number: 1,
  published_at: thread.published_at,
  content_html: thread.content_html,
  author_snapshot: thread.author_snapshot
};

const allPosts = [mainPost, ...posts];
---

<BaseLayout title={`${thread.title} - ${board.name} - 旧时论坛`}>

  <div class="breadcrumb">
    <a href="/">旧时论坛</a> &raquo; <a href={`/boards/${board.slug}`}>{board.name}</a> &raquo; <span>{thread.title}</span>
  </div>

  <div class="pagination" style="margin-top: 0;">
    {pagination.page > 1 ? <a href={`?page=${pagination.page - 1}`}>&lt; 上一页</a> : <span class="disabled">&lt; 上一页</span>}
    <span class="current">{pagination.page}</span>
    {pagination.page < pagination.totalPages ? <a href={`?page=${pagination.page + 1}`}>下一页 &gt;</a> : <span class="disabled">下一页 &gt;</span>}
    <span>共 {pagination.totalPages} 页</span>
  </div>

  <div class="thread-container">
    <div class="forum-box-header" style="font-size: 16px;">
      本主题：{thread.title}
    </div>

    {allPosts.map((post: any) => (
      <div class="post-row">
        <!-- 左侧：用户侧栏 -->
        <div class="post-sidebar">
          <div class="font-bold" style="margin-bottom: 10px; font-size: 14px; color: var(--link-color);">
            {post.author_snapshot.display_name}
          </div>
          <div class="avatar-wrap">
            <img class="avatar" src={post.author_snapshot.avatar_url} alt="头像" onerror="this.removeAttribute('src'); this.setAttribute('class', 'avatar missing-avatar');" />
          </div>
          <div class="font-bold" style="color: #cc0000; margin-bottom: 5px;">
            {post.author_snapshot.user_group_name}
          </div>
          
          <ul class="user-info-list">
            <li>头衔: {post.author_snapshot.user_title}</li>
            <li>版号: {post.author_snapshot.board_title}</li>
            <li>积分: {post.author_snapshot.points_display}</li>
            <li>发帖: {post.author_snapshot.post_count_display}</li>
            <li>精华: {post.author_snapshot.essence_count_display}</li>
            <li>注册: {post.author_snapshot.registered_at_display}</li>
            <li>来自: {post.author_snapshot.location_display}</li>
          </ul>

          {post.author_snapshot.badges && post.author_snapshot.badges.length > 0 && (
            <div class="badges">
              {post.author_snapshot.badges.map((badge: any) => (
                <div class="badge" title={badge.name}>
                  <img src={badge.icon_url} alt={badge.name} onerror="this.style.display='none'" />
                  <span>{badge.name}</span>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- 右侧：正文与签名档 -->
        <div class="post-main">
          <div class="post-header">
            <div>
              <span>发表于 {new Date(post.published_at).toLocaleString()}</span>
            </div>
            <div class="font-bold">
              {post.floor_number === 1 ? '楼主' : `${post.floor_number} 楼`}
            </div>
          </div>
          
          <div class="post-content">
            <Fragment set:html={post.content_html} />
          </div>

          {post.author_snapshot.signature_text && (
            <div class="post-signature">
              {post.author_snapshot.signature_text}
            </div>
          )}
        </div>
      </div>
    ))}

    {posts.length === 0 && (
      <div class="empty-state">
        暂时还没有人跟帖
      </div>
    )}
  </div>

  <div class="pagination">
    {pagination.page > 1 ? <a href={`?page=${pagination.page - 1}`}>&lt; 上一页</a> : <span class="disabled">&lt; 上一页</span>}
    <span class="current">{pagination.page}</span>
    {pagination.page < pagination.totalPages ? <a href={`?page=${pagination.page + 1}`}>下一页 &gt;</a> : <span class="disabled">下一页 &gt;</span>}
    <span>共 {pagination.totalPages} 页</span>
  </div>

</BaseLayout>
