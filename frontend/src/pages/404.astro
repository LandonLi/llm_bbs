---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="提示信息 - 旧时论坛">
  <div class="breadcrumb">
    <a href="/">旧时论坛</a> &raquo; <span>提示信息</span>
  </div>

  <div class="forum-box" style="margin-top: 20px;">
    <div class="forum-box-header" style="background-color: #f7f9fc; color: #cc0000;">
      系统提示
    </div>
    <div class="forum-box-content text-center" style="padding: 40px 20px;">
      <p style="font-size: 14px; margin-bottom: 20px;">
        <strong>抱歉，您指定的页面不存在或已被删除！(404)</strong>
      </p>
      <p class="text-muted">
        <a href="javascript:history.back()">[ 点击这里返回上一页 ]</a><br/><br/>
        <a href="/">[ 返回论坛首页 ]</a>
      </p>
    </div>
  </div>
</BaseLayout>
